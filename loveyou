<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Official Date Application ❤️</title>

<link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;500;700&display=swap" rel="stylesheet">

<style>
*{margin:0;padding:0;box-sizing:border-box}
body{
    font-family:Poppins,sans-serif;
    background:linear-gradient(135deg,#ff9ecf,#ffd6e8,#ffe9f2);
    overflow-x:hidden;
    min-height:100vh;
}
body::before{
    content:"❤️ ❤️ 💕 💖 💗";
    position:fixed;
    font-size:40px;
    opacity:.15;
    width:100%;
    animation:float 20s linear infinite;
}
@keyframes float{
0%{transform:translateY(100vh)}
100%{transform:translateY(-120vh)}
}
#loading{
position:fixed;
inset:0;
background:#ff5f9e;
display:flex;
justify-content:center;
align-items:center;
flex-direction:column;
color:white;
font-size:1.3rem;
z-index:9999;
transition:1s;
}
.bar{
width:280px;
height:16px;
background:white;
border-radius:20px;
margin-top:20px;
overflow:hidden;
}
.fill{
height:100%;
width:0%;
background:#ffdd57;
animation:load 4s forwards;
}
@keyframes load{
0%{width:0}
100%{width:100%}
}
.container{
max-width:700px;
margin:60px auto;
background:white;
padding:35px;
border-radius:25px;
box-shadow:0 15px 45px rgba(0,0,0,.15);
animation:appear .8s;
}
@keyframes appear{
from{transform:translateY(40px);opacity:0}
to{transform:none;opacity:1}
}
h1{text-align:center;color:#ff3c88;margin-bottom:10px}
.subtitle{text-align:center;color:#666;margin-bottom:30px}
.section{margin:22px 0}
label{display:block;margin:10px 0;font-weight:500}
input[type=date],input[type=time],select{
width:100%;
padding:12px;
border-radius:10px;
border:1px solid #ddd;
font-size:16px;
}
button{
margin-top:25px;
width:100%;
padding:15px;
font-size:18px;
border:none;
background:#ff4d94;
color:white;
border-radius:15px;
cursor:pointer;
transition:.3s;
}
button:hover{
transform:scale(1.03);
background:#ff267b;
}
.result{
display:none;
text-align:center;
padding:25px;
}
.result h2{
color:#ff2d75;
margin-bottom:10px;
}
.small{
font-size:.95rem;
color:#666;
}
.confetti{
position:fixed;
width:10px;
height:10px;
top:-20px;
animation:fall 4s linear forwards;
}
@keyframes fall{
to{
transform:translateY(110vh) rotate(720deg);
opacity:0;
}
}
</style>
</head>

<body>

<div id="loading">
<h2>Checking compatibility... ❤️</h2>
<p id="status">Analyzing smiles...</p>

<div class="bar">
<div class="fill"></div>
</div>
</div>

<div class="container">

<h1>💕 Official Date Application 💕</h1>
<p class="subtitle">
Applicant: Me ❤️<br>
Reviewer: The Most Amazing Girl Ever
</p>

<form id="form">

<div class="section">
<label>Will you go on a date with me?</label>

<label><input type="radio" name="yes" required> Absolutely ❤️</label>
<label><input type="radio" name="yes"> Yes 😍</label>
<label><input type="radio" name="yes"> Of course 😏</label>
<label><input type="radio" name="yes"> Why are these all the same? 😂</label>

</div>

<div class="section">
<label>Pick our date 📅</label>
<input type="date" id="date" required>
</div>

<div class="section">
<label>Preferred time ⏰</label>
<input type="time" id="time">
</div>

<div class="section">
<label>What should we eat? 🍽️</label>

<select id="food">
<option>🍕 Pizza</option>
<option>🍔 Burgers</option>
<option>🍣 Sushi</option>
<option>🍝 Pasta</option>
<option>🌮 Tacos</option>
<option>🍗 Fried Chicken</option>
<option>🍜 Ramen</option>
<option>🍰 Dessert Only 😋</option>
<option>✨ Surprise Me</option>
</select>
</div>

<div class="section">

<label>Choose our activity ❤️</label>

<label><input type="checkbox"> 🎬 Movie</label>
<label><input type="checkbox"> ☕ Coffee</label>
<label><input type="checkbox"> 🌙 Night Walk</label>
<label><input type="checkbox"> 🎮 Arcade</label>
<label><input type="checkbox"> 🍦 Ice Cream</label>
<label><input type="checkbox"> ❤️ Just spending time together</label>

</div>

<div class="section">

<label>Emergency Question 😂</label>

<label><input type="radio" name="hand"> Holding hands is allowed.</label>
<label><input type="radio" name="hand"> Hold my hand tighter.</label>
<label><input type="radio" name="hand"> Only if you buy dessert.</label>

</div>

<button>💖 Approve Date Request</button>

</form>

<div class="result" id="result">

<h2>Application Approved! ❤️</h2>

<p>
Congratulations! 🎉<br><br>

Our date is officially scheduled for:

<br><br>

<b id="summary"></b>

<br><br>

I promise:
<br>✅ To make you laugh.
<br>✅ To steal at least one french fry.
<br>✅ To have an amazing time together.
</p>

<p class="small">
Compatibility Score: <b>100%</b> ❤️
</p>

</div>

</div>

<script>

const msgs=[
"Analyzing smiles... 😊",
"Calculating butterflies... 🦋",
"Checking snack compatibility... 🍕",
"Consulting Cupid... 🏹",
"Almost there... ❤️"
];

let i=0;
const interval=setInterval(()=>{
document.getElementById("status").innerText=msgs[i%msgs.length];
i++;
},700);

setTimeout(()=>{
clearInterval(interval);
document.getElementById("loading").style.opacity="0";
setTimeout(()=>{
document.getElementById("loading").style.display="none";
},1000);
},4200);

document.getElementById("form").onsubmit=function(e){

e.preventDefault();

const d=document.getElementById("date").value;
const t=document.getElementById("time").value;
const f=document.getElementById("food").value;

document.getElementById("summary").innerHTML=
`${d}<br>${t}<br>${f}`;

document.getElementById("form").style.display="none";
document.getElementById("result").style.display="block";

confetti();

};

function confetti(){

const colors=["#ff4d94","#ffcc00","#66ccff","#8aff80","#ffffff"];

for(let i=0;i<180;i++){

let c=document.createElement("div");

c.className="confetti";

c.style.left=Math.random()*100+"vw";

c.style.background=colors[Math.floor(Math.random()*colors.length)];

c.style.animationDuration=(Math.random()*3+2)+"s";

c.style.width=(Math.random()*8+6)+"px";

c.style.height=c.style.width;

document.body.appendChild(c);

setTimeout(()=>c.remove(),5000);

}

}

</script>

</body>
</html>
```

